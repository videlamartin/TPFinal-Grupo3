<!DOCTYPE html>
<html>
<head>
    <title>QuizMaster - Mi Perfil</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://www.w3schools.com/w3css/4/w3.css">
    <style>
        body {
            background: linear-gradient(135deg,#4facfe,#00f2fe);
            min-height: 100vh;
            font-family: Arial, sans-serif;
        }
        .avatar {
            width: 100px; height: 100px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid white;
        }
        .avatar-placeholder {
            width: 100px; height: 100px;
            border-radius: 50%;
            background: #ccc;
            display: flex; align-items: center; justify-content: center;
            font-size: 40px;
            margin: 0 auto;
        }
    </style>
</head>
<body>

<div class="w3-container w3-padding-32" style="max-width:600px; margin:0 auto;">

    <h1 style="color:white; text-align:center;"> Mi Perfil</h1>

    <div class="w3-card-4 w3-white w3-round-xlarge w3-padding-32">

        <div class="w3-center w3-margin-bottom">
            {{#foto_perfil}}
                <img src="{{foto_perfil}}" class="avatar">
            {{/foto_perfil}}
            {{^foto_perfil}}
                <div class="avatar-placeholder"></div>
            {{/foto_perfil}}
        </div>

        <table class="w3-table">
            <tr><td><b>Nombre</b></td><td>{{nombre_completo}}</td></tr>
            <tr><td><b>Usuario</b></td><td>@{{username}}</td></tr>
            <tr><td><b>Email</b></td><td>{{email}}</td></tr>
            <tr><td><b>País</b></td><td>{{pais}}</td></tr>
            <tr><td><b>Ciudad</b></td><td>{{ciudad}}</td></tr>
            <tr><td><b>Puntaje</b></td><td>{{puntaje_total}} pts</td></tr>
            <tr><td><b>Rol</b></td><td>{{rol}}</td></tr>
        </table>

        <div class="w3-center w3-margin-top">
            <a href="/lobby/ver"
               class="w3-button w3-blue w3-round-xlarge">
                ← Volver al Lobby
            </a>
        </div>

    </div>

</div>

</body>
</html>