<!DOCTYPE html>
<html lang="es">
<head>
    <title>QuizMaster - Sugerir pregunta</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://www.w3schools.com/w3css/4/w3.css">
    <link rel="stylesheet" href="/public/css/lobby.css">
    <link rel="stylesheet" href="/public/css/editor-form.css">
</head>
<body>

<div class="titulo">QuizMaster</div>
<div class="subtitulo">Sugerir una pregunta</div>

<div class="w3-container w3-padding-32">
    <div class="w3-card-4 w3-white panel-juego" style="max-width:700px; margin:0 auto;">
        <div class="w3-container w3-padding">

            <p class="w3-text-grey" style="margin-bottom:20px;">
                Tu pregunta será revisada por un editor antes de aparecer en el juego.
            </p>

            <form method="POST" action="/lobby/sugerirGuardar">

                <!-- Enunciado -->
                <div class="w3-margin-bottom">
                    <label class="w3-text-blue"><b>Enunciado</b></label>
                    <textarea name="enunciado"
                              class="w3-input w3-border w3-round"
                              rows="3"
                              required></textarea>
                </div>

                <!-- Categoría -->
                <div class="w3-margin-bottom">
                    <label class="w3-text-blue"><b>Categoría</b></label>
                    <select name="categoria_id"
                            class="w3-select w3-border w3-round"
                            required>
                        <option value="" disabled selected>Seleccioná una categoría</option>
                        {{#categorias}}
                        <option value="{{id}}">{{nombre}}</option>
                        {{/categorias}}
                    </select>
                </div>

                <!-- Respuestas -->
                <div class="w3-margin-bottom">
                    <label class="w3-text-blue"><b>Respuestas</b></label>
                    <p class="w3-text-grey" style="margin:4px 0 12px;">
                        Marcá con el círculo cuál es la correcta.
                    </p>

                    {{#campos_crear}}
                    <div class="respuesta-row w3-margin-bottom">
                        <div class="respuesta-radio">
                            <input type="radio"
                                   name="respuesta_correcta"
                                   value="{{indice}}"
                                   required>
                        </div>
                        <div class="respuesta-input">
                            <input type="text"
                                   name="respuesta_texto[]"
                                   class="w3-input w3-border w3-round"
                                   placeholder="Respuesta {{indice_display}}"
                                   required>
                        </div>
                    </div>
                    {{/campos_crear}}
                </div>

                <button type="submit" class="w3-button w3-round-xlarge form-btn btn-verde">
                    Enviar sugerencia
                </button>

                <a href="/lobby/ver" class="w3-button w3-grey w3-round-xlarge form-btn" style="margin-top:8px;">
                    Cancelar
                </a>

            </form>
        </div>
    </div>
</div>

</body>
</html>