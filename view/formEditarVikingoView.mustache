{{>header}}
<div class="container">
    <form action="/vikingo/procesarEditar" method="POST">
        <input type="hidden" name="id" value="{{id}}">

        <div class="form-group">
            <label for="nombre">Nombre del Guerrero</label>
            <input type="text" id="nombre" name="nombre" value="{{nombre}}" required>
        </div>

        <div class="form-group">
            <label for="apodo">Apodo (Si lo tiene)</label>
            <input type="text" id="apodo" name="apodo" value="{{apodo}}">
        </div>

        <div class="form-group">
            <label for="clan">Clan / Asentamiento</label>
            <input type="text" id="clan" name="clan" value="{{clan}}">
        </div>

        <div class="form-group">
            <label for="fuerza">Nivel de Fuerza (0 - 100)</label>
            <input type="number" id="fuerza" name="fuerza" min="0" max="100" value="{{fuerza}}">
        </div>

        <button type="submit" class="btn-submit">⚔️ GUARDAR CAMBIOS</button>

        <a href="/vikingo" class="back-link">← Volver al Salón del Trono</a>
    </form>
</div>
{{>footer}}
