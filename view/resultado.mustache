<!DOCTYPE html>
<html>
<head>
    <title>QuizMaster - Resultado</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://www.w3schools.com/w3css/4/w3.css">
    <link rel="stylesheet" href="/public/css/resultado.css">
</head>
<body>

<div class="titulo">QuizMaster</div>
<div class="subtitulo">Resultado de la partida</div>

<div class="w3-container">
    <div class="w3-card-4 w3-white panel-juego w3-margin-top">
        <div class="w3-container w3-padding">

            <h2>Partida finalizada</h2>
            <hr>
            <h3>Puntaje final: <b>{{puntaje}}</b></h3>

            <p><b>Motivo de finalización:</b> {{motivo_fin}}</p>

            {{#respuesta_correcta}}
                <p><b>Respuesta correcta:</b> {{respuesta_correcta}}</p>
            {{/respuesta_correcta}}

            {{#pregunta_reportable_id}}
                <div class="w3-margin-top">
                    <button type="button" id="btn-mostrar-reporte"
                            class="w3-button w3-red w3-block w3-round-xlarge"
                            onclick="document.getElementById('form-reporte').style.display='block'; this.style.display='none';">
                            Reportar esta pregunta
                    </button>

                    <form id="form-reporte" action="/partida/reportar" method="POST"
                          style="display:none;" class="w3-padding w3-light-grey w3-round">
                        <p style="margin:0 0 8px;">¿Por qué querés reportar esta pregunta?</p>
                        <input type="hidden" name="pregunta_id" value="{{pregunta_reportable_id}}">
                        <input type="hidden" name="puntaje"     value="{{puntaje}}">
                        <input type="hidden" name="motivo_fin"  value="{{motivo_fin}}">
                        <input type="text" name="motivo" class="w3-input w3-border w3-margin-bottom"
                               placeholder="Motivo" required>
                        <button type="submit" class="w3-button w3-red w3-block w3-round-xlarge">
                            Enviar reporte
                        </button>
                    </form>
                </div>
            {{/pregunta_reportable_id}}

            {{#reportado}}
                <div class="w3-panel w3-green w3-round w3-margin-top">
                    <p>✓ ¡Gracias! Tu reporte fue enviado y será revisado por un editor.</p>
                </div>
            {{/reportado}}

            <div class="w3-margin-top">
                <a href="/partida/iniciar" class="w3-button btn-naranja w3-block w3-margin-bottom">
                    Jugar de nuevo
                </a>
                <a href="/lobby/ver" class="w3-button btn-azul w3-block">
                    Volver al lobby
                </a>
            </div>

        </div>
    </div>
</div>

</body>
</html>