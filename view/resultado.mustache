<!DOCTYPE html>
<html>
<head>
    <title>QuizMaster - Resultado</title>

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet"
          href="https://www.w3schools.com/w3css/4/w3.css">

    <style>

        body{
            background: linear-gradient(135deg,#4facfe,#00f2fe);
            min-height:100vh;
            font-family: Arial, sans-serif;
            margin:0;
        }

        .w3-container{
            text-align:center;
        }
        .titulo{
            font-size:42px;
            font-weight:bold;
            text-align:center;
            color:white;
            text-shadow: 2px 2px 5px rgba(0,0,0,.3);
            margin-top:20px;
        }

        .subtitulo{
            text-align:center;
            color:white;
            margin-bottom:20px;
        }

        .panel-juego{
            border-radius:20px;
            overflow:hidden;
            animation: aparecer .4s ease;
        }

        .btn-naranja{
            background:#ff9800 !important;
            color:white !important;
            border-radius:25px;
            transition:.3s;
        }

        .btn-naranja:hover{
            transform:scale(1.05);
            background:#ffb74d !important;
        }

        .btn-verde{
            background:#43a047 !important;
            color:white !important;
            border-radius:25px;
            transition:.3s;
        }

        .btn-verde:hover{
            transform:scale(1.05);
        }

        .btn-azul{
            background:#1e88e5 !important;
            color:white !important;
            border-radius:25px;
            transition:.3s;
        }

        .btn-azul:hover{
            transform:scale(1.05);
        }

        .btn-rojo{
            background:#e53935 !important;
            color:white !important;
            border-radius:25px;
            transition:.3s;
        }

        .btn-rojo:hover{
            transform:scale(1.05);
        }

        @keyframes aparecer{
            from{
                opacity:0;
                transform:translateY(15px);
            }
            to{
                opacity:1;
                transform:translateY(0);
            }
        }

        @media (max-width: 600px) {

            .titulo{
                font-size: 30px;
                margin-top: 15px;
            }

            .w3-container{
                text-align: center;
                padding-left: 10px !important;
                padding-right: 10px !important;
                padding-bottom: 10px !important;
            }

            .panel-juego{
                margin: 10px;
            }
        }

    </style>
</head>

<body>

<div class="titulo">
    QuizMaster
</div>

<div class="subtitulo">
    Resultado de la partida
</div>

<div class="w3-container">

    <div class="w3-card-4 w3-white panel-juego w3-margin-top">

        <div class="w3-container w3-padding ">

            <h2> Partida finalizada</h2>

            <hr>

            <h3>Puntaje final: <b>{{puntaje}}</b></h3>

            <p>
                <b>Motivo de finalización:</b>
                {{motivo_fin}}
            </p>

            {{#respuesta_correcta}}
                <p>
                    <b>Respuesta correcta:</b>
                    {{respuesta_correcta}}
                </p>
            {{/respuesta_correcta}}

            <div class="w3-margin-top">

                <a href="/partida/iniciar"
                   class="w3-button btn-naranja w3-block w3-margin-bottom">
                    Jugar de nuevo
                </a>

                <a href="/lobby/ver"
                   class="w3-button btn-azul w3-block">
                    Volver al lobby
                </a>

            </div>

        </div>

    </div>

</div>

</body>
</html>