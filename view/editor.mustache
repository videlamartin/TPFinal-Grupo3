<!DOCTYPE html>
<html lang="es">
<head>
    <title>QuizMaster - Editor</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://www.w3schools.com/w3css/4/w3.css">
    <link rel="stylesheet" href="/public/css/lobby.css">
    <link rel="stylesheet" href="/public/css/editor.css">
</head>
<body>

<div class="titulo">QuizMaster</div>
<div class="subtitulo">Panel de Editor</div>

<div class="w3-container w3-padding-32">

    <div class="w3-card-4 w3-white panel-juego" style="max-width:900px; margin:0 auto;">
        <div class="w3-container w3-padding">

            <div class="w3-row w3-margin-bottom">
                <div class="w3-col s6">
                    <h2 style="margin:0;">Preguntas</h2>
                </div>
                <div class="w3-col s6 w3-right-align">
                    <a href="/editor/crear"
                       class="w3-button w3-green w3-round-xlarge">
                        + Nueva pregunta
                    </a>
                </div>
            </div>

            <!-- Buscador -->
            <form method="GET" action="/editor/ver" class="w3-margin-bottom">
               <div class="buscador-container">
                   <input type="text"
                          name="busqueda"
                          value="{{busqueda}}"
                          placeholder="Buscar por enunciado..."
                          class="w3-input w3-border w3-round-xlarge">

                   <button type="submit"
                           class="w3-button w3-blue w3-round-xlarge">
                       Buscar
                   </button>

               </div>
            </form>

<div class="preguntas-grid">

    {{#preguntas}}
    <div class="pregunta-card">

        <div class="pregunta-header">
            <span class="categoria-badge"
                  style="background:{{categoria_color}};">
                {{categoria_nombre}}
            </span>

            <span class="estado-pregunta">
                {{estado}}
            </span>
        </div>

        <h3 class="pregunta-enunciado">
            {{enunciado}}
        </h3>

        <div class="acciones">
            <a href="/editor/modificar?id={{id}}"
               class="w3-button w3-blue w3-round-xlarge">
                Editar
            </a>

            <form method="POST"
                  action="/editor/eliminar"
                  class="accion-form"
                  onsubmit="return confirm('¿Rechazar esta pregunta?')">

                <input type="hidden" name="id" value="{{id}}">

                <button type="submit"
                        class="w3-button w3-red w3-round-xlarge">
                    Rechazar
                </button>
            </form>
        </div>

    </div>
    {{/preguntas}}

    {{^preguntas}}
    <div class="sin-resultados">
        No hay preguntas que coincidan con la búsqueda.
    </div>
    {{/preguntas}}

</div>
            <a href="/lobby/ver"
               class="w3-button w3-grey w3-round-xlarge w3-margin-top">
                ← Volver al lobby
            </a>

        </div>
    </div>
</div>

</body>
</html>