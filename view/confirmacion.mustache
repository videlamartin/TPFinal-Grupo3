    <title>QuizMaster - ¡Registro exitoso!</title>
    <link rel="stylesheet" href="https://www.w3schools.com/w3css/4/w3.css">
    <link rel="stylesheet" href="/public/css/confirmacion.css">
</head>
<body>

<div class="wrapper">
    <div class="icono">🎉</div>
    <div class="titulo">¡Registro exitoso!</div>
