<!DOCTYPE html>
<html lang="es">
<head>
    <title>QuizMaster - Juego</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://www.w3schools.com/w3css/4/w3.css">
    <link rel="stylesheet" href="/public/css/juego.css">
</head>
<body class="{{categoria_actual}}">

<div id="ruleta-overlay">
    <div class="ruleta-aguja"></div>
    <div id="ruleta"></div>
    <div id="ruleta-texto">Sorteando categoría...</div>
</div>

<div class="contenedor-juego">
    <h1 style="color:white; text-align:center; margin:0 0 4px;">PREGUNTADOS</h1>
    <h2 style="color:white; text-align:center; margin:0 0 24px; font-weight:normal; font-size:1.1em;">
        ¡Demuestra tu capacidad intelectual!
    </h2>

    <div class="panel w3-card-4 w3-white w3-round-xlarge w3-padding-32">

        <div class="timer-wrap">
            <div class="w3-row">
                <div class="w3-col s6 w3-left-align">Tiempo</div>
                <div class="w3-col s6 w3-right-align">
                    <span class="timer-num" id="timer-num">{{tiempo_limite}}</span>s
                </div>
            </div>
            <div class="barra-tiempo">
                <div id="barra-tiempo-fill"></div>
            </div>
        </div>

        <div class="w3-center w3-margin-bottom">
            <span class="w3-badge"
                  style="background-color: {{categoria_color}}; color: white; padding: 5px 15px;">
                {{categoria}}
            </span>
        </div>

        <h3 class="w3-center" style="margin-bottom: 30px; font-weight: bold;">
            {{pregunta}}
        </h3>

        <form action="/partida/responder" method="POST">
            {{#respuestas}}
                <button type="submit" name="respuesta_id" value="{{id}}"
                        class="w3-button w3-block w3-blue w3-round-xlarge w3-margin-bottom">
                    {{texto}}
                </button>
            {{/respuestas}}
        </form>

        <form id="form-timeout" action="/partida/responder" method="POST" style="display:none;">
            <input type="hidden" name="respuesta_id" value="0">
        </form>

        <div class="w3-row w3-margin-top w3-border-top w3-padding-top">
            <div class="w3-col s6 w3-left-align">Puntaje: <b>{{puntaje_actual}}</b></div>
        </div>

    </div>
</div>

<!-- Variables del servidor para el JS -->
<script>
    var tiempoTotal     = {{tiempo_limite}};
    var tiempoFin       = {{tiempo_fin}}; // timestamp en ms (hora real del servidor)
    var categoriaActual = "{{categoria_actual}}";
    var colorActual     = "{{categoria_color_actual}}";
</script>
<script src="/public/js/juego.js"></script>

</body>
</html>